{
  "name": "platform-status-monitor",
  "private": true,
  "version": "0.1.0",
  "description": "Agent-configurable platform status monitoring for teams and client operators.",
  "license": "MIT",
  "packageManager": "pnpm@11.1.2",
  "scripts": {
    "build": "turbo run build",
    "check": "turbo run check",
    "dev": "turbo run dev --parallel",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "export:schema": "pnpm --filter @platform-status-monitor/shared export:schema",
    "validate:config": "pnpm --filter @platform-status-monitor/shared validate:config"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "prettier": "^3.8.4",
    "turbo": "^2.9.18",
    "typescript": "^6.0.3"
  },
  "pnpm": {
    "overrides": {
      "postcss": "8.5.15",
      "next@16.2.6>postcss": "8.5.15"
    }
  }
}
