name = "platform-status-monitor-worker"
main = "src/index.ts"
compatibility_date = "2026-05-13"

kv_namespaces = [
  { binding = "PSM_STATE", id = "replace-with-kv-namespace-id" }
]

[triggers]
crons = ["*/5 * * * *"]

[vars]
INSTALL_CONFIG_PATH = "config/install.example.json"
PSM_ALLOWED_ORIGINS = "http://localhost:3000"
PSM_PUBLIC_READS = "false"
