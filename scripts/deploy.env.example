# PSM deploy configuration — copy to scripts/deploy.env and fill in.
# scripts/deploy.env is gitignored.

# Cloudflare API token with Pages + Workers + KV scope (required).
CLOUDFLARE_API_TOKEN=

# Public URL of the deployed Worker — used by the web build (baked into the
# Next.js bundle as NEXT_PUBLIC_WORKER_BASE_URL) and by post-deploy smoke tests.
# Example: https://my-psm-worker.example.workers.dev
PSM_WORKER_URL=

# Public URL of the deployed Pages site — used by post-deploy smoke tests.
# Example: https://psm.example.com
PSM_PAGES_URL=

# Cloudflare Pages project name (must match the project created in Cloudflare).
# Example: platformstatusmonitor
PSM_PAGES_PROJECT_NAME=

# Optional: Pages branch to deploy to. Defaults to "main".
# PSM_DEPLOY_BRANCH=main
