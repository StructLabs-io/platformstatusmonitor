{
  "name": "Example Platform Status Monitor Install",
  "timezone": "America/New_York",
  "dashboard": {
    "tiers": [
      {
        "id": "tier-1",
        "displayName": "Tier 1",
        "description": "Most critical platforms for the install.",
        "platforms": ["airtable"]
      },
      {
        "id": "tier-2",
        "displayName": "Tier 2",
        "description": "Important platforms with operational workarounds.",
        "platforms": []
      },
      {
        "id": "tier-3",
        "displayName": "Tier 3",
        "description": "Supporting platforms monitored for visibility.",
        "platforms": []
      }
    ]
  },
  "platforms": {
    "airtable": {
      "displayName": "Airtable",
      "statusPageUrl": "https://status.airtable.com",
      "ingestion": ["rss", "webhook"],
      "services": {
        "interfaces": {"displayName": "Interfaces"},
        "automations": {"displayName": "Automations"},
        "api": {"displayName": "API"}
      },
      "zones": ["global", "us", "eu"]
    }
  },
  "dependents": {
    "example-client": {
      "type": "client",
      "displayName": "Example Client",
      "timezone": "America/New_York",
      "activeHours": {"start": "09:00", "end": "18:00"},
      "dependencies": [
        {
          "platform": "airtable",
          "services": ["interfaces", "automations"],
          "zones": ["us", "global"],
          "criticality": "high",
          "environment": "production"
        }
      ]
    }
  },
  "venues": {
    "webapp": {
      "type": "webapp",
      "displayName": "Webapp Only"
    }
  },
  "routingRules": [
    {
      "id": "show-major-incidents",
      "match": {
        "severities": ["critical", "major"]
      },
      "actions": [
        {"venue": "webapp"}
      ],
      "options": {
        "respectActiveHours": false,
        "notifyOnResolved": true
      }
    }
  ]
}
