{
  "title": "PlatformStatusMonitorInstallConfig",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "timezone": {
      "type": "string"
    },
    "dashboard": {
      "default": {
        "tiers": []
      },
      "type": "object",
      "properties": {
        "tiers": {
          "default": [],
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "displayName": {
                "type": "string",
                "minLength": 1
              },
              "description": {
                "type": "string"
              },
              "platforms": {
                "default": [],
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              }
            },
            "required": [
              "id",
              "displayName",
              "platforms"
            ],
            "additionalProperties": false
          }
        }
      },
      "required": [
        "tiers"
      ],
      "additionalProperties": false
    },
    "platforms": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "type": "object",
        "properties": {
          "displayName": {
            "type": "string",
            "minLength": 1
          },
          "statusPageUrl": {
            "type": "string",
            "format": "uri"
          },
          "providerType": {
            "type": "string",
            "enum": [
              "statuspage",
              "rss",
              "incidentio",
              "instatus",
              "synthetic"
            ]
          },
          "rssFeedUrl": {
            "type": "string",
            "format": "uri"
          },
          "syntheticCheckUrl": {
            "type": "string",
            "format": "uri"
          },
          "ingestion": {
            "minItems": 1,
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "rss",
                "webhook",
                "synthetic"
              ]
            }
          },
          "services": {
            "default": {},
            "type": "object",
            "propertyNames": {
              "type": "string"
            },
            "additionalProperties": {
              "type": "object",
              "properties": {
                "displayName": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "required": [
                "displayName"
              ],
              "additionalProperties": false
            }
          },
          "zones": {
            "default": [
              "global"
            ],
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "required": [
          "displayName",
          "ingestion",
          "services",
          "zones"
        ],
        "additionalProperties": false
      }
    },
    "dependents": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "client",
              "project",
              "team",
              "environment",
              "internal-system"
            ]
          },
          "displayName": {
            "type": "string",
            "minLength": 1
          },
          "timezone": {
            "type": "string",
            "minLength": 1
          },
          "activeHours": {
            "type": "object",
            "properties": {
              "start": {
                "type": "string",
                "pattern": "^\\d{2}:\\d{2}$"
              },
              "end": {
                "type": "string",
                "pattern": "^\\d{2}:\\d{2}$"
              }
            },
            "required": [
              "start",
              "end"
            ],
            "additionalProperties": false
          },
          "dependencies": {
            "default": [],
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "platform": {
                  "type": "string",
                  "minLength": 1
                },
                "services": {
                  "default": [],
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "zones": {
                  "default": [
                    "global"
                  ],
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "criticality": {
                  "default": "medium",
                  "type": "string",
                  "enum": [
                    "critical",
                    "high",
                    "medium",
                    "low"
                  ]
                },
                "environment": {
                  "default": "production",
                  "type": "string"
                }
              },
              "required": [
                "platform",
                "services",
                "zones",
                "criticality",
                "environment"
              ],
              "additionalProperties": false
            }
          }
        },
        "required": [
          "type",
          "displayName",
          "timezone",
          "dependencies"
        ],
        "additionalProperties": false
      }
    },
    "venues": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "oneOf": [
          {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "const": "webapp"
              },
              "displayName": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "type",
              "displayName"
            ],
            "additionalProperties": false
          },
          {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "const": "telegram"
              },
              "displayName": {
                "type": "string",
                "minLength": 1
              },
              "botTokenSecret": {
                "type": "string",
                "minLength": 1
              },
              "chatIdEnv": {
                "type": "string",
                "minLength": 1
              },
              "topicIdEnv": {
                "type": "string"
              }
            },
            "required": [
              "type",
              "displayName",
              "botTokenSecret",
              "chatIdEnv"
            ],
            "additionalProperties": false
          },
          {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "const": "slack"
              },
              "displayName": {
                "type": "string",
                "minLength": 1
              },
              "webhookUrlEnv": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "type",
              "displayName",
              "webhookUrlEnv"
            ],
            "additionalProperties": false
          }
        ]
      }
    },
    "routingRules": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "match": {
            "type": "object",
            "properties": {
              "dependents": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "platforms": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "services": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "zones": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "severities": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": [
                    "critical",
                    "major",
                    "minor",
                    "maintenance",
                    "info"
                  ]
                }
              },
              "statuses": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": [
                    "investigating",
                    "identified",
                    "monitoring",
                    "resolved",
                    "postmortem"
                  ]
                }
              },
              "environments": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "labels": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "additionalProperties": false
          },
          "actions": {
            "minItems": 1,
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "venue": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "required": [
                "venue"
              ],
              "additionalProperties": false
            }
          },
          "options": {
            "default": {},
            "type": "object",
            "properties": {
              "respectActiveHours": {
                "default": true,
                "type": "boolean"
              },
              "bypassQuietHours": {
                "default": false,
                "type": "boolean"
              },
              "notifyOnResolved": {
                "default": true,
                "type": "boolean"
              }
            },
            "additionalProperties": false
          }
        },
        "required": [
          "id",
          "match",
          "actions",
          "options"
        ],
        "additionalProperties": false
      }
    },
    "notificationFilters": {
      "default": {
        "severityFloor": [
          "critical",
          "major"
        ],
        "perPlatform": {}
      },
      "type": "object",
      "properties": {
        "severityFloor": {
          "default": [
            "critical",
            "major"
          ],
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "critical",
              "major"
            ]
          }
        },
        "perPlatform": {
          "default": {},
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "type": "object",
            "properties": {
              "enabled": {
                "default": true,
                "type": "boolean"
              },
              "componentAllowlist": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "componentDenylist": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "regionAllowlist": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              }
            },
            "required": [
              "enabled"
            ],
            "additionalProperties": false
          }
        }
      },
      "required": [
        "severityFloor",
        "perPlatform"
      ],
      "additionalProperties": false
    }
  },
  "required": [
    "name",
    "platforms",
    "dependents",
    "venues",
    "routingRules"
  ],
  "additionalProperties": false
}
